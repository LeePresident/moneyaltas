{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "flutter pub get",
      "type": "shell",
      "command": "flutter",
      "args": ["pub", "get"],
      "problemMatcher": ["$dart"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "flutter clean",
      "type": "shell",
      "command": "flutter",
      "args": ["clean"],
      "problemMatcher": ["$dart"]
    },
    {
      "label": "flutter test",
      "type": "shell",
      "command": "flutter",
      "args": ["test"],
      "problemMatcher": ["$dart"],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}
