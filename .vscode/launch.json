{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "console": "debugConsole",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Flutter (Windows)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "console": "debugConsole",
      "cwd": "${workspaceFolder}",
      "args": ["-d", "windows"]
    },
    {
      "name": "Flutter (Web)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "console": "debugConsole",
      "cwd": "${workspaceFolder}",
      "args": ["-d", "web-server"]
    }
  ]
}
